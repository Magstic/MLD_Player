<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true"
    android:paddingStart="20dp"
    android:paddingTop="24dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/import_page_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/import_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/open_folder_button"
                style="@style/Widget.MLDPlayer.TonalAction"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:contentDescription="@string/open_folder"
                android:gravity="center"
                android:padding="0dp"
                app:icon="@drawable/ic_add"
                app:iconGravity="textTop"
                app:iconPadding="0dp"
                app:iconSize="34dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/recent_empty_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/folder_list_empty"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recent_imports_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>

</ScrollView>
