<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.MLDPlayer.Card.Hero" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">32dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

    <style name="Widget.MLDPlayer.Card.Section" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

    <style name="Widget.MLDPlayer.Card.Subtle" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant</item>
    </style>

    <style name="Widget.MLDPlayer.Card.ListItem" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

    <style name="Widget.MLDPlayer.IconButton" parent="Widget.Material3.Button.IconButton.Outlined">
        <item name="android:minWidth">64dp</item>
        <item name="android:minHeight">64dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MLDPlayer.Large</item>
    </style>

    <style name="Widget.MLDPlayer.TransportButton" parent="Widget.MLDPlayer.IconButton">
        <item name="android:minWidth">76dp</item>
        <item name="android:minHeight">76dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MLDPlayer.Transport</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="Widget.MLDPlayer.TransportButton.Primary" parent="Widget.MLDPlayer.TransportButton">
        <item name="android:minWidth">92dp</item>
        <item name="android:minHeight">92dp</item>
    </style>

    <style name="Widget.MLDPlayer.TonalAction" parent="Widget.Material3.Button.TonalButton">
        <item name="shapeAppearance">@style/ShapeAppearance.MLDPlayer.Medium</item>
    </style>

    <style name="Widget.MLDPlayer.NavButton" parent="Widget.Material3.Button.TonalButton">
        <item name="shapeAppearance">@style/ShapeAppearance.MLDPlayer.NavButton</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="iconGravity">textTop</item>
        <item name="iconPadding">0dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="ShapeAppearance.MLDPlayer.Large" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="ShapeAppearance.MLDPlayer.Medium" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="ShapeAppearance.MLDPlayer.Transport" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">30dp</item>
    </style>

    <style name="ShapeAppearance.MLDPlayer.NavButton" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>
</resources>
